[
  {
    "bindings": {
      "cmd-g": "git_panel::Toggle",
      "cmd-e": "project_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-g": "git_panel::ToggleFocus"
    },
    "unbind": {
      "ctrl-shift-g": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\u001b\r"]
    }
  },
  {
    "context": "GitPanel && ChangesList && !GitBranchSelector",
    "bindings": {
      "cmd-g": "git_panel::ToggleFocus"
    },
    "unbind": {
      "escape": "git_panel::ToggleFocus"
    }
  }
]
